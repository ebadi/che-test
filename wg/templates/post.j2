<!DOCTYPE HTML>

<html lang="en">
  <head>
    <meta charset="utf-8">

    <title>{{title}}</title>
    <meta name="description" content="{{description}} {{title}}">
    <meta name="author" content="{{author}}">
    
    <link rel="stylesheet" href="{{style}}.css">
    <link rel="stylesheet" href="spectre.min.css">
  </head>
  
  <header class="navbar">
    <section class="navbar-section">
      <a href="{{url}}" class="btn btn-primary">{{title}}</a>
    </section>
  </header>
  
  <body>
    <div class="content">
      <h2>{{post_title}}
      <h5>{{date}}</h5>
      <div class="container grid-lg">
	<div class="columns">
	  <div class="column col-xs-1">{{content}}</div>
	</div>
      </div>
    </div>


  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-3281J0VDJP"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());

    gtag('config', 'G-3281J0VDJP');
  </script>
  

  </body>
  
  <footer>
    <center><p>Copyright © {{year}} {{author}}</p></center>
  </footer>
</html>
 
